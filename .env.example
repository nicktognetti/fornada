# Variáveis de ambiente do Fornada (Flor do Trigo)
# Copie para .env.local (desenvolvimento) e configure as MESMAS no Vercel (produção).
# Os valores reais ficam no painel do Supabase: Project Settings > API.

# URL do projeto Supabase (público — vai pro client)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anônima (público — vai pro client; protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-a-anon-key-aqui

# Chave service_role (SECRETA — NUNCA exponha no client; só Server Actions/API)
# No Vercel, marque como "Sensitive" e disponível só em Production/Preview.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui
